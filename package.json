{
  "name": "agentic-product-development-harness",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "bin": {
    "p-dev": "./bin/p-dev-dev.js"
  },
  "description": "Cursor-first Linear/GitHub/GitHub Actions orchestration harness (SDK runners planning–merge, event-driven auto-run).",
  "scripts": {
    "dev": "node bin/gui-dev.js",
    "gui:dev": "node bin/gui-dev.js",
    "start": "node bin/p-dev-dev.js",
    "p-dev:install": "tsx scripts/install-p-dev-local.ts",
    "build": "tsc && npm run copy:eval-assets && npm run build:gui",
    "build:tsc": "tsc && npm run copy:eval-assets",
    "copy:eval-assets": "node scripts/copy-evaluation-assets.mjs",
    "build:gui": "next build apps/gui",
    "test": "vitest run",
    "harness:eval:subjects": "tsx src/index.ts eval subjects",
    "harness:eval:subjects-list": "tsx src/index.ts eval subjects-list",
    "harness:eval:annotation-bundle": "tsx src/index.ts eval annotation-bundle",
    "harness:eval:annotate": "tsx src/index.ts eval annotate",
    "harness:eval:annotation-validate": "tsx src/index.ts eval annotation-validate",
    "harness:eval:annotation-coverage": "tsx src/index.ts eval annotation-coverage",
    "harness:eval:dataset-readiness": "tsx src/index.ts eval dataset-readiness",
    "harness:eval:annotation-export": "tsx src/index.ts eval annotation-export",
    "harness:eval:evaluators-list": "tsx src/index.ts eval evaluators-list",
    "harness:eval:evaluator-plan": "tsx src/index.ts eval evaluator-plan",
    "harness:eval:evaluate": "tsx src/index.ts eval evaluate",
    "harness:eval:evaluator-validate": "tsx src/index.ts eval evaluator-validate",
    "harness:eval:evaluator-summary": "tsx src/index.ts eval evaluator-summary",
    "evaluation:inspect-langfuse": "tsx src/index.ts eval inspect-langfuse",
    "evaluation:reproject-langfuse": "tsx src/index.ts eval reproject-langfuse",
    "evaluation:canary-langfuse-projection": "tsx src/index.ts eval canary-langfuse-projection",
    "evaluation:canary-native-skill": "tsx src/index.ts eval canary-native-skill",
    "prompts:validate": "tsx src/index.ts prompts:validate",
    "prompts:langfuse:sync": "tsx src/index.ts prompts:langfuse:sync",
    "generate:evaluator-manifest": "node scripts/generate-evaluator-manifest.mjs",
    "test:webhook": "vitest run tests/webhook",
    "harness:gui": "node bin/p-dev-dev.js",
    "harness:configure": "node bin/p-dev-dev.js --deprecation-notice=configure",
    "harness:configure:stable": "node bin/p-dev-dev.js --deprecation-notice=configure",
    "harness:gui:doctor": "tsx src/gui/gui-doctor.ts",
    "harness:doctor": "tsx src/index.ts doctor",
    "harness:diagnose:vercel-bridge": "tsx src/index.ts diagnose-vercel-bridge",
    "harness:run": "tsx src/index.ts run",
    "harness:inspect": "tsx src/index.ts inspect",
    "harness:validate-issue": "tsx src/index.ts validate-issue",
    "harness:resolve-route": "tsx src/index.ts resolve-route",
    "harness:claim-job-request": "tsx src/index.ts claim-job-request",
    "harness:private-state-canary": "tsx src/index.ts private-state-canary",
    "harness:reconcile-revision": "tsx src/index.ts reconcile-revision",
    "harness:reconcile-merge": "tsx src/index.ts reconcile-merge",
    "harness:reconcile-workflow": "tsx src/index.ts reconcile-workflow",
    "harness:workflow-status-report": "tsx src/index.ts workflow-status-report",
    "harness:workflow-status-migrate": "tsx src/index.ts workflow-status-migrate",
    "harness:validation-run": "tsx src/index.ts validation-run",
    "harness:sync-production": "tsx src/index.ts sync-production",
    "harness:canary-runner-config": "tsx src/index.ts canary-runner-config",
    "release:sync-managed-runner": "tsx src/index.ts sync-managed-runner",
    "harness:redact-output": "tsx src/index.ts redact-output",
    "harness:operator:init": "tsx src/index.ts operator init",
    "generate:config-schema": "tsx scripts/generate-config-schema.ts",
    "package:p-dev:prepare": "tsx scripts/prepare-p-dev-package.ts",
    "package:p-dev:pack": "npm run package:p-dev:prepare && sh -c 'cd packages/p-dev && npm pack --pack-destination .'",
    "package:p-dev:inspect": "sh -c 'cd packages/p-dev && npm pack --dry-run --json'",
    "test:workflow:browser": "playwright test --config scripts/workflow-browser-matrix.config.ts",
    "test:configure:browser": "playwright test --config scripts/configure-browser-matrix.config.ts",
    "test:operator:browser": "playwright test --config scripts/operator-gui-smoke.config.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@langfuse/client": "^5.9.1",
    "@langfuse/otel": "^5.9.1",
    "@langfuse/tracing": "^5.9.1",
    "@linear/sdk": "^40.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/node": "^9.47.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "posthog-node": "^5.26.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.7.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "tweetsodium": "^0.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "zod-to-json-schema": "^3.24.5"
  }
}
